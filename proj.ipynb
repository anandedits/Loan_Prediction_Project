# ============================================================================
# 3. DATA CLEANING
# ============================================================================

def clean_data(df: pd.DataFrame) -> pd.DataFrame:
    """Clean and preprocess raw data (handle missing values, etc.)."""
    print("\n" + "=" * 80)
    print("DATA CLEANING")
    print("=" * 80)

    df_clean = df.copy()

    # Handle missing values
    print("\nHandling missing values...")

    # Fill missing age with median
    if df_clean["usia"].isnull().sum() > 0:
        median_age = df_clean["usia"].median()
        missing_age = df_clean["usia"].isnull().sum()
        df_clean["usia"].fillna(median_age, inplace=True)
        print(f"  - Filled {missing_age} missing age values with median: {median_age}")

    # Fill missing employment status with mode
    if df_clean["status_pekerjaan"].isnull().sum() > 0:
        mode_status = df_clean["status_pekerjaan"].mode()[0]
        missing_status = df_clean["status_pekerjaan"].isnull().sum()
        df_clean["status_pekerjaan"].fillna(mode_status, inplace=True)
        print(f"  - Filled {missing_status} missing employment status with mode: {mode_status}")

    print(f"\nCleaned dataset shape: {df_clean.shape}")
    print(f"Remaining missing values: {df_clean.isnull().sum().sum()}")

    return df_clean


